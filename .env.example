# Kopiraj u .env.local i popuni prave vrednosti.
# (.env.local NE ide na Git — vidi .gitignore)

# Server-only — Make webhook za lead submit (klijent daje URL, uključi scenario na Make-u)
MAKE_WEBHOOK_URL=

# Shopify — za checkout permalink na Thank You strani
NEXT_PUBLIC_SHOPIFY_DOMAIN=noro.rs
NEXT_PUBLIC_DISCOUNT_CODE=NORO_POPUST
NEXT_PUBLIC_DISCOUNT_PERCENT=20
