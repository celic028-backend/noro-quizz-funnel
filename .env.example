# Kopiraj u .env.local i popuni.
# NAPOMENA: na GitHub Pages (static) nema servera, pa webhook ide iz browsera —
# zato je NEXT_PUBLIC (URL je vidljiv u JS bundle-u). Za skriveni webhook treba server host.

NEXT_PUBLIC_MAKE_WEBHOOK_URL=
NEXT_PUBLIC_SHOPIFY_DOMAIN=noro.rs
NEXT_PUBLIC_DISCOUNT_CODE=NORO_POPUST
NEXT_PUBLIC_DISCOUNT_PERCENT=20
